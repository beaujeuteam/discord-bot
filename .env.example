# Token du bot Discord (obtenu sur https://discord.com/developers/applications)
DISCORD_TOKEN=ton_token_ici

# ID de l'application Discord
CLIENT_ID=ton_client_id_ici

# (Optionnel) ID du serveur pour le déploiement des commandes en développement
GUILD_ID=ton_guild_id_ici

# Clé API Mistral (obtenue sur https://console.mistral.ai/)
MISTRAL_API_KEY=ta_cle_api_mistral_ici

# Port de l'interface web de la soundboard (défaut : 3000)
WEB_PORT=3000

# (Optionnel) Répertoire des fichiers audio de la soundboard (défaut : ./sounds)
SOUNDS_DIR=./sounds
